# Mailjet — https://app.mailjet.com/account/api_keys
# Sender domain for info@blackmattertech.com must be verified in Mailjet.
MAILJET_API_KEY=
MAILJET_SECRET_KEY=

MAILJET_FROM_EMAIL=info@blackmattertech.com
MAILJET_FROM_NAME=BlackMatter Technologies

# Internal notification recipient
CONTACT_INBOX_EMAIL=verma@blackmatter.com

# Optional: production site origin for CORS (e.g. https://blackmattertech.com)
# CORS_ORIGIN=

# API port (default 8787)
# PORT=8787

# Optional: Google Analytics 4 — only loads after the user accepts cookies in the banner
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Supabase (CRM/contact submissions)
# Project URL: https://app.supabase.com/project/<project-ref>
SUPABASE_URL=
# Server-side key for inserts from your backend API (keep secret; never expose in frontend)
SUPABASE_SERVICE_ROLE_KEY=
# Optional: table name used for storing contact leads
# SUPABASE_CONTACTS_TABLE=contact_submissions

# Optional frontend usage (only if you read data in client apps)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
