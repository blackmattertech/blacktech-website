# Mailjet — https://app.mailjet.com/account/api_keys
# Sender domain for info@blackmattertech.com must be verified in Mailjet.
MAILJET_API_KEY=
MAILJET_SECRET_KEY=

MAILJET_FROM_EMAIL=info@blackmattertech.com
MAILJET_FROM_NAME=BlackMatter Technologies

# Internal notification recipient
CONTACT_INBOX_EMAIL=verma@blackmatter.com

# Optional: production site origin for CORS (e.g. https://blackmattertech.com)
# CORS_ORIGIN=

# API port (default 8787)
# PORT=8787
